{
	"name": "discord-defender",
	"private": true,
	"type": "module",
	"files": [
		"distribution"
	],
	"scripts": {
		"build": "tsc",
		"test": "tsc --noEmit",
		"format": "biome check --write",
		"lint": "biome check",
		"knip": "knip",
		"dev": "tsx --env-file=.env.development source/index.ts | pino-pretty",
		"start": "node --import ./distribution/sentry.js distribution/index.js",
		"deploy-commands-dev": "tsx --env-file=.env.development source/utility/deploy-commands.ts | pino-pretty",
		"deploy-commands": "tsx source/utility/deploy-commands.ts"
	},
	"dependencies": {
		"@discordjs/collection": "dev",
		"@discordjs/core": "dev",
		"@discordjs/rest": "dev",
		"@discordjs/ws": "dev",
		"@sentry/node": "^10.56.0",
		"kysely": "^0.29.0",
		"pg": "^8.22.0",
		"pino": "^10.3.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@actions/core": "^2.0.2",
		"@biomejs/biome": "2.3.11",
		"@types/node": "^26.1.0",
		"@types/pg": "^8.20.0",
		"knip": "^5.88.1",
		"pino-pretty": "^13.1.3",
		"tsx": "4.22.4",
		"typescript": "^6.0.3"
	}
}
